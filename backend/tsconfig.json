{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",          // 1. Change from Node16 to NodeNext
    "moduleResolution": "NodeNext",  // 2. Change from Node16 to Bundler
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}